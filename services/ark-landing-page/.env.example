# ARK Landing Page Environment Variables

# Production URL Configuration - Choose ONE strategy:

# Option 1: Single dashboard URL with namespace parameter
# NEXT_PUBLIC_ARK_DASHBOARD_URL=https://dashboard.your-domain.com

# Option 2: Subdomain per demo
# NEXT_PUBLIC_BASE_DOMAIN=demos.your-domain.com

# Leave both empty for local development defaults:
# - Landing: http://localhost:3002
# - Dashboard: http://localhost:3003?namespace={demo-name}

# Authentication Configuration
# AUTH_MODE can be 'open' or 'sso'
# When set to 'open', no authentication is required
# When set to 'sso', users must authenticate via OIDC
AUTH_MODE=open

# OIDC Configuration (required when AUTH_MODE=sso)
# OIDC_ISSUER_URL=https://your-identity-provider.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_PROVIDER_NAME=Your Identity Provider
# OIDC_PROVIDER_ID=your-provider

# NextAuth Configuration (required when AUTH_MODE=sso)
# Generate a random secret: openssl rand -base64 32
# AUTH_SECRET=your-nextauth-secret
# AUTH_URL=https://landing.your-domain.com
# BASE_URL=https://landing.your-domain.com

# Session Configuration (optional)
# SESSION_MAX_AGE=1800
# AUTH_DEBUG=false
